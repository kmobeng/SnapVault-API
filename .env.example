# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:4000

# Database
DB_URL=mongodb://localhost:27017/snapvault

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key
ACCESS_JWT_EXPIRES_IN=expires_in_minutes
ACCESS_JWT_COOKIE_EXPIRES_IN=expires_in_minutes
REFRESH_JWT_COOKIE_EXPIRES_IN=expires_in_days

# Cookie Session (OAuth)
COOKIE_KEY=your_cookie_session_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email
EMAIL_FROM=SnapVault <noreply@yourdomain.com>

# SendGrid (production)
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=your_sendgrid_api_key
